# 🚀 CodeBuddy Backend Environment Variables

# Server Port
PORT=5000

# MongoDB Connection String (Atlas or Local)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/codebuddy

# Firebase Admin SDK Credentials
# Note: PRIVATE_KEY should have escaped newlines (\n) if in a single line
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Groq AI Key - Get a free key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Email Configuration (for contact form/notifications)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Optional: Judge0 RapidAPI Key (for robust cloud execution)
RAPIDAPI_KEY=your_rapidapi_key_here
